  @@index([workspaceId, relatedContactId, createdAt, id], map: "Commitment_workspace_contact_created_idx")
  @@index([workspaceId, relatedCompanyId, createdAt, id], map: "Commitment_workspace_company_created_idx")
  @@index([workspaceId, relatedOpportunityId, createdAt, id], map: "Commitment_workspace_opportunity_created_idx")
  @@index([workspaceId, relatedMeetingId, createdAt, id], map: "Commitment_workspace_meeting_created_idx")
  @@index([workspaceId, relatedOpportunityId])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, ownerUserId])
}

model Blocker {
  id                   String        @id @default(cuid())
  workspaceId          String
  title                String
  blockerType          String
  blockerText          String
  severity             Int           @default(50)
  sourceType           SourceType
  sourceId             String
  relatedContactId     String?
  relatedCompanyId     String?
  relatedOpportunityId String?
  relatedMeetingId     String?
  status               BlockerStatus @default(OPEN)
  resolutionNote       String?
  firstSeenAt          DateTime      @default(now())
  resolvedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  workspace            Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  relatedContact       Contact?      @relation("ContactBlockers", fields: [relatedContactId], references: [id], onDelete: SetNull)
  relatedCompany       Company?      @relation("CompanyBlockers", fields: [relatedCompanyId], references: [id], onDelete: SetNull)
  relatedOpportunity   Opportunity?  @relation("OpportunityBlockers", fields: [relatedOpportunityId], references: [id], onDelete: SetNull)
  relatedMeeting       Meeting?      @relation("MeetingBlockers", fields: [relatedMeetingId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt, id], map: "Blocker_workspace_created_idx")
  @@index([workspaceId, relatedContactId, createdAt, id], map: "Blocker_workspace_contact_created_idx")
  @@index([workspaceId, relatedCompanyId, createdAt, id], map: "Blocker_workspace_company_created_idx")
  @@index([workspaceId, relatedOpportunityId, createdAt, id], map: "Blocker_workspace_opportunity_created_idx")
  @@index([workspaceId, relatedMeetingId, createdAt, id], map: "Blocker_workspace_meeting_created_idx")
  @@index([workspaceId, relatedOpportunityId])
  @@index([workspaceId, severity])
}

model BriefingSnapshot {
  id                  String     @id @default(cuid())
  workspaceId         String
  objectType          ObjectType
  objectId            String
  snapshotType        String
  content             String     @db.LongText
  sourceFactIds       String?    @db.LongText
  sourceCommitmentIds String?    @db.LongText
  sourceBlockerIds    String?    @db.LongText
  generatedAt         DateTime   @default(now())
  expiresAt           DateTime?
  version             Int        @default(1)
  workspace           Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, objectType, objectId, snapshotType])
}

model CaptureSession {
  id               String                  @id @default(cuid())
  workspaceId      String
  userId           String?
  linkedMeetingId  String?
  title            String?
  status           CaptureSessionStatus    @default(RECORDING)
  sourceType       CaptureSourceType       @default(MANUAL_CAPTURE)
  sourceId         String?
  objectType       ObjectType?
  objectId         String?
  startedAt        DateTime                @default(now())
  endedAt          DateTime?
  durationSeconds  Int?
  transcriptStatus CaptureProcessingStatus @default(PENDING)
  processingStatus CaptureProcessingStatus @default(PENDING)
  errorMessage     String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  workspace        Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user             User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  linkedMeeting    Meeting?                @relation("CaptureSessionMeeting", fields: [linkedMeetingId], references: [id], onDelete: SetNull)
  transcript       ConversationTranscript?
  insights         ConversationInsight[]
  consentRecord    CaptureConsentRecord?

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, objectType, objectId])
}

model CaptureConsentRecord {
  id                   String               @id @default(cuid())
  workspaceId          String
  captureSessionId     String               @unique
  confirmedByUserId    String?
  confirmedByName      String
  method               CaptureConsentMethod @default(UI_CHECKBOX)
  noticeTextVersion    String               @default("capture-consent-notice/v1")
  counterpartyNotified Boolean              @default(false)
  confirmedAt          DateTime             @default(now())
  workspace            Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  captureSession       CaptureSession       @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)
  confirmedByUser      User?                @relation(fields: [confirmedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, confirmedAt])
}

model ConversationTranscript {
  id               String               @id @default(cuid())
  workspaceId      String
  captureSessionId String               @unique
  fullText         String               @db.LongText
  segments         String?              @db.LongText
  speakerSeparated Boolean              @default(false)
  language         String               @default("zh-CN")
  confidence       Int                  @default(70)
  sourceType       TranscriptSourceType @default(FALLBACK_DEMO)
  provider         String?
  model            String?
  createdAt        DateTime             @default(now())
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  captureSession   CaptureSession       @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model ConversationInsight {
  id                   String                  @id @default(cuid())
  workspaceId          String
  captureSessionId     String
  insightType          ConversationInsightType
  title                String
  content              String                  @db.LongText
  confidence           Int                     @default(70)
  relatedContactId     String?
  relatedCompanyId     String?
  relatedOpportunityId String?
  relatedMeetingId     String?
  sourceSegmentRefs    String?                 @db.LongText
  createdAt            DateTime                @default(now())
  workspace            Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  captureSession       CaptureSession          @relation(fields: [captureSessionId], references: [id], onDelete: Cascade)
  relatedContact       Contact?                @relation("ConversationInsightContact", fields: [relatedContactId], references: [id], onDelete: SetNull)
  relatedCompany       Company?                @relation("ConversationInsightCompany", fields: [relatedCompanyId], references: [id], onDelete: SetNull)
  relatedOpportunity   Opportunity?            @relation("ConversationInsightOpportunity", fields: [relatedOpportunityId], references: [id], onDelete: SetNull)
  relatedMeeting       Meeting?                @relation("ConversationInsightMeeting", fields: [relatedMeetingId], references: [id], onDelete: SetNull)

  @@index([workspaceId, captureSessionId])
  @@index([workspaceId, insightType, createdAt])
  @@index([workspaceId, relatedOpportunityId])
  @@index([workspaceId, relatedContactId])
}

model RecommendationLog {
  id                    String                   @id @default(cuid())
  workspaceId           String
  userId                String?
  objectType            ObjectType
  objectId              String
  actionType            ActionType
  title                 String
  description           String                   @db.LongText
  recommendationPayload String?                  @db.LongText
  score                 Int                      @default(0)
  urgencyScore          Int                      @default(0)
  impactScore           Int                      @default(0)
  confidenceScore       Int                      @default(0)
  personalizationScore  Int                      @default(0)
  policyFitScore        Int                      @default(0)
  riskScore             Int                      @default(0)
  policyResult          ActionExecutionMode
  supportingFactIds     String?                  @db.LongText
  blockerIds            String?                  @db.LongText
  commitmentIds         String?                  @db.LongText
  explanation           String                   @db.LongText
  status                RecommendationStatus     @default(ACTIVE)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  workspace             Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                  User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  feedbacks             RecommendationFeedback[]
  actionItems           ActionItem[]

  @@index([workspaceId, objectType, objectId])
  @@index([workspaceId, userId])
  @@index([workspaceId, status])
}

model RecommendationFeedback {
  id                  String                     @id @default(cuid())
  workspaceId         String
  recommendationLogId String
  userId              String?
  feedbackType        RecommendationFeedbackType
  edited              Boolean                    @default(false)
  resultNote          String?
  rejectionReasonCode RejectionReasonCode?
  actionItemId        String?
  approvalTaskId      String?
  createdAt           DateTime                   @default(now())
  workspace           Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recommendationLog   RecommendationLog          @relation(fields: [recommendationLogId], references: [id], onDelete: Cascade)
  user                User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, recommendationLogId])
  @@index([workspaceId, feedbackType])
}

model PreferenceSignal {
  id                     String               @id @default(cuid())
  workspaceId            String
  userId                 String?
  signalType             PreferenceSignalType
  signalKey              String
  signalValue            String
  sourceActionId         String?
  sourceRecommendationId String?
  weight                 Int                  @default(50)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  workspace              Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                   User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, userId, signalType])
  @@index([workspaceId, signalKey])
}

model LLMCallLog {
  id                   String    @id @default(cuid())
  workspaceId          String
  userId               String?
  provider             String
  model                String
  modelVersion         String?
  modelRole            String?
  taskType             String
  promptKey            String?
  promptVersion        String
  budgetTier           String?
  outputMode           String?
  inputSummary         String?
  outputSummary        String?
  tokenUsagePrompt     Int?
  tokenUsageCompletion Int?
  latencyMs            Int?
  success              Boolean   @default(true)
  fallbackReason       String?
  errorMessage         String?
  createdAt            DateTime  @default(now())
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, taskType])
  @@index([workspaceId, provider, model])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, promptKey, promptVersion])
  @@index([workspaceId, modelRole])
}

enum TrialApplicationStatus {
  PENDING
  CONTACTED
  APPROVED
  REJECTED
}

// Public trial-application intake. The applicant has no workspace yet, so this
// model intentionally has no workspaceId. Reviews run from the Helm reserved
// workspace via the /admin/trials surface.
model TrialApplication {
  id               String                 @id @default(cuid())
  email            String
  organizationName String
  role             String
  useCase          String                 @db.LongText
  status           TrialApplicationStatus @default(PENDING)
  submittedLocale  String?
  decisionReason   String?                @db.LongText
  decidedByUserId  String?
  decidedAt        DateTime?
  notifiedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([status, createdAt])
  @@index([email])
}
