        { "assertionId": "cov:pm", "system": "pm", "scope": "delivery_projects", "windowStart": "2026-04-01T00:00:00Z", "windowEnd": "2026-06-04T00:00:00Z", "method": "webhook_plus_backfill", "completeness": "complete", "evidence": ["backfill_checkpoint=2026-04-01", "webhook_live", "no_gap"], "asOf": "2026-06-04T00:00:00Z" }
      ],
      "triggerFacts": [
        { "system": "crm", "entity": "deal", "factId": "deal-A", "matchValue": "deal-A", "occurredAt": "2026-05-01T00:00:00Z" },
        { "system": "crm", "entity": "deal", "factId": "deal-B", "matchValue": "deal-B", "occurredAt": "2026-05-10T00:00:00Z", "ownerCandidates": [ { "id": "user:alex-alias", "kind": "user", "active": true, "roleEvidence": ["crm:deal-owner", "hr:active-tenure"] } ] },
