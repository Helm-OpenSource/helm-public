{
  "name": "helm-console",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "node scripts/fix-local-lightningcss-signature.mjs",
    "prepare": "husky",
    "lint": "eslint app components data features hooks lib prisma scripts tests eslint.config.mjs next.config.ts playwright.config.ts postcss.config.mjs vitest.config.ts vitest.public.config.ts",
    "lint:strict": "eslint --max-warnings 0 app components data features hooks lib prisma scripts tests eslint.config.mjs next.config.ts playwright.config.ts postcss.config.mjs vitest.config.ts vitest.public.config.ts",
    "typecheck": "tsc --noEmit --project tsconfig.public.json",
    "validate:env": "node --import tsx scripts/validate-env.ts",
    "delivery:doctor": "node --import tsx scripts/delivery-engineer-doctor.ts",
    "pack:fixture-check": "node --import tsx scripts/pack-fixture-check.ts",
    "self-check": "npm run public:smoke:static",
    "check:public-release": "node --import tsx scripts/public-release-guard.ts",
    "check:secret-history": "node --import tsx scripts/secret-history-check.ts",
    "db:generate": "prisma generate --schema prisma/schema.prisma && prisma generate --schema prisma/schema.sqlite.prisma",
    "db:prepare": "node -e \"console.log('public mirror: database prepare is not required')\"",
    "test": "vitest run --config vitest.public.config.ts",
    "test:public:guards": "vitest run lib/public-release-guard.test.ts lib/public-mirror-semantic-entry-docs.test.ts",
    "quality:regression": "npm run test:public:guards && npm run public:smoke:static",
    "public:e2e:smoke": "npm run public:smoke:static",
    "e2e": "npm run public:e2e:smoke",
    "check:boundaries": "npm run public:smoke:static",
    "public:smoke:static": "tsx scripts/public-mirror-smoke.ts --repo-root .",
    "public:smoke": "tsx scripts/public-mirror-smoke.ts --repo-root . --run-commands"
  },
  "prisma": {
    "seed": "env LLM_ENABLED=false node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/nodemailer": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "imapflow": "^1.3.1",
    "lucide-react": "^0.577.0",
    "mailparser": "^3.9.8",
    "next": "16.2.6",
    "nodemailer": "^8.0.5",
    "pinyin-pro": "^3.28.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4"
  }
}
