{
  "version": "channel-partner-collaboration-p0-v2.1",
  "status": "offline_evaluation_fixture",
  "redactionPosture": "alias_only_no_real_customer_identity",
  "boundary": "p0_offline_only_no_schema_no_migration_no_runtime_no_api_no_ui_no_outbound_send",
  "sourceDoc": "docs/product/HELM_CHANNEL_PARTNER_COLLABORATION_REQUIREMENTS_2026-05-12.md",
  "scope": "P0-REQ-08",
  "notes": [
    "All customer identifiers are alias-only (alias-cust-a, alias-cust-b, ...).",
    "No real workspace names, URLs, slugs, industry, size, or amounts appear.",
    "Fixture pack does not import any runtime, DB, schema, API, UI, network, or LLM surface.",
    "P0 only freezes offline contract; P1 internal implementation and P2 PartnerWorkspace runtime stay out-of-scope."
  ],
  "targets": {
    "minimumTotalCases": 20,
    "minimumNudgeLifecycleCoverageCount": 5,
    "minimumRevocationCoverageCount": 2,
    "minimumAttributionLedgerAnchorCoverageCount": 2,
    "minimumPartnerSafeDtoCoverageCount": 3,
    "maximumUnauthorizedAccessCount": 0,
    "maximumOutboundSendIncidentCount": 0,
    "maximumDisclosureMissingCount": 0,
    "maximumAttributionUniquenessViolations": 0,
    "maximumPartnerDataLeakedToCustomerWorkspaceCount": 0,
    "maximumCustomerDataRawLeakedToPartnerCount": 0,
    "maximumDirectRecommendationCreationByPartnerCount": 0,
    "maximumAskHelmAccessByPartnerCount": 0,
    "maximumCrossTenantHelperLeakCount": 0,
    "maximumDirectSourceTableReadCount": 0,
    "maximumMissingGrantAcceptedCount": 0,
    "maximumUnauthorizedNudgeAcceptanceCount": 0,
    "maximumSchemaRuntimeApiUiIncidentCount": 0,
    "maximumPartnerWorkspaceRuntimeIncidentCount": 0
  },
  "cases": [
    {
      "id": "CP-001-GRANT-MISSING-REJECT",
      "scenario": "grant_missing_reject",
      "description": "Partner attempts PartnerSafe DTO readout without any PartnerCustomerGrant; system must reject.",
      "actor": "partner",
      "request": "read_partner_safe_dto",
      "dtoUsed": "PartnerSafeRecommendationDTO",
      "grant": { "present": false, "status": "missing" },
      "expect": {
        "outcome": "rejected",
        "reasonCodes": ["partner_grant_required"],
        "flags": {},
        "coverage": { "partnerSafeDto": true }
      }
    },
    {
      "id": "CP-002-GRANT-REJECTED-BY-CUSTOMER",
      "scenario": "grant_rejected",
      "description": "Customer admin rejected the inbound PartnerCustomerGrant request; partner cannot read.",
      "actor": "partner",
      "request": "read_partner_safe_dto",
      "dtoUsed": "PartnerSafeMustPushDTO",
      "grant": { "present": true, "status": "rejected" },
      "expect": {
        "outcome": "rejected",
        "reasonCodes": ["partner_grant_required"],
        "flags": {},
        "coverage": { "partnerSafeDto": true }
      }
    },
    {
      "id": "CP-003-SAFE-DTO-ALLOWLIST",
      "scenario": "partner_safe_dto_allowed",
      "description": "Active grant + read via PartnerSafeRecommendationDTO white list; allowed but only via projection, not raw table.",
      "actor": "partner",
      "request": "read_partner_safe_dto",
      "dtoUsed": "PartnerSafeRecommendationDTO",
      "grant": { "present": true, "status": "active" },
      "expect": {
        "outcome": "allowed",
        "reasonCodes": ["partner_safe_dto_only"],
        "flags": {},
        "coverage": { "partnerSafeDto": true }
      }
    },
    {
      "id": "CP-004-DIRECT-SOURCE-TABLE-READ-REJECT",
      "scenario": "direct_source_table_read_rejected",
      "description": "Partner attempts to select directly from raw Recommendation source table; must be rejected by safe-DTO boundary.",
      "actor": "partner",
      "request": "read_source_table",
      "dtoUsed": "raw_source_table",
      "grant": { "present": true, "status": "active" },
      "expect": {
        "outcome": "rejected",
        "reasonCodes": ["partner_safe_dto_only", "raw_source_table_blocked"],
        "flags": {},
        "coverage": { "partnerSafeDto": true }
      }
    },
    {
      "id": "CP-005-ASK-HELM-REJECT",
      "scenario": "ask_helm_blocked",
      "description": "Partner attempts to issue an Ask Helm query against customer workspace; must be hard-blocked (P0-REQ-02 black list).",
      "actor": "partner",
      "request": "ask_helm_invocation",
      "grant": { "present": true, "status": "active" },
      "expect": {
        "outcome": "rejected",
        "reasonCodes": ["partner_ask_helm_forbidden"],
        "flags": {}
      }
    },
    {
      "id": "CP-006-OUTBOUND-SEND-REJECT",
