      "node scripts/codex-hooks/post-edit-debug-artifact-check.cjs",
      "node scripts/codex-hooks/post-edit-accumulator.cjs"
    ],
    "stop": [
      "node scripts/codex-hooks/stop-validation-reminder.cjs"
    ]
  }
}
