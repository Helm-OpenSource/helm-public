{
  "note": "Public-safe synthetic scenario for the Cross-System Accountability Gap MVP. No real data. now is passed for deterministic evaluation.",
  "now": "2026-06-04T00:00:00Z",
  "rule": {
    "ruleId": "won-deal-needs-delivery-handoff",
    "version": "1.0.0",
    "description": "A won CRM deal should have a delivery/handoff project in the PM system within N days.",
    "trigger": { "system": "crm", "entity": "deal", "condition": "stage=won" },
    "expectation": { "system": "pm", "entity": "delivery_project", "withinDays": 7, "matchKey": "dealId" },
    "requiredCoverage": ["crm", "pm"],
    "ownerPolicyRef": "policy:delivery-owner",
    "commitmentClass": "advice",
    "effectMode": "read_only",
    "forbiddenActions": ["auto_create_record", "auto_dispatch", "auto_chase", "auto_write_source", "external_send", "approval"]
  },
  "ownerPolicy": { "policyRef": "policy:delivery-owner", "escalationRoleRef": "role:delivery-escalation" },
