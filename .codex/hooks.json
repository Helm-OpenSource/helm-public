    ],
    "pre_bash": [
      "node scripts/codex-hooks/pre-bash-block-no-verify.cjs",
      "node scripts/codex-hooks/pre-bash-git-push-reminder.cjs"
    ],
    "pre_edit": [
      "node scripts/codex-hooks/pre-edit-config-protection.cjs"
    ],
    "post_edit": [
