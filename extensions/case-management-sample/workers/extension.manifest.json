{
  "manifestVersion": "1",
  "bundleVersion": "2026.05.26",
  "extensionKey": "case-management-sample-workers",
  "tenantKey": "case-management-sample",
  "extensionSlug": "workers",
  "displayName": "Case Management Sample Workers",
  "kind": "TENANT_CUSTOM",
  "status": "ACTIVE",
  "owner": "helm-open-source",
  "nonCoreDeclaration": true,
  "compatibility": {
    "minRuntimeContractVersion": "2026.05.26-public-sample",
    "supportedWorkspaceClasses": [
      "CUSTOMER"
    ],
    "requiredFeatures": [
      "WorkspaceSolutionExtension"
    ]
  },
  "migrationHints": [
    "bundle_manifest_read_only_validation_phase4"
  ],
  "runtimeDeclarations": {
    "workers": [
      "case-allocation-driver",
      "case-stewardship-driver"
    ],
    "skills": [],
    "resources": [],
    "hooks": [],
    "monitors": [],
    "surfaces": [
      "/operating",
      "/approvals"
    ]
  },
  "capabilityManifest": {
