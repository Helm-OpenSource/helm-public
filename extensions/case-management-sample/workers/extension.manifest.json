      "case-import-source"
    ],
    "workspaceTruths": [
      "WorkspaceSolutionExtension"
    ],
    "policyTruths": [
      "review-first",
      "observer-first"
    ]
  },
  "documentationPointers": {
    "readme": "../README.md",
    "docs": [
      "../hsi-implementation-checklist.md"
    ]
  },
  "evalContract": {
    "fixtures": [],
    "checks": [
      "manifest.test.ts",
      "worker-modes.test.ts",
      "lifecycle-objectives.test.ts",
      "case-allocation-driver/decide.test.ts",
      "case-stewardship-driver/decide.test.ts"
    ]
  },
  "summary": "Public sample worker bundle for review-first case allocation and stewardship.",
  "surfaces": [
    "/operating",
    "/approvals"
  ]
}
