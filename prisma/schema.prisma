// GTMLead — Helm reserved tenant 自营增长闭环起点（V2.3 §7.1）。
// 不是给普通客户租户使用的 CRM；只允许在 reserved workspace 内可见和写入。
// 不替代外部 CRM；只承载 Helm 自营 GTM 判断、证据和下一步动作。
model GtmLead {
  id                   String                @id @default(cuid())
  workspaceId          String
  leadKey              String
  sourceType           GtmLeadSourceType
  sourceRef            String?
  referrerMembershipId String?
  companyName          String
  industry             String?
  icpFit               GtmLeadIcpFit         @default(UNKNOWN)
  readinessStage       GtmLeadReadinessStage @default(UNKNOWN)
  ownerMembershipId    String?
  stage                GtmLeadStage          @default(CAPTURED)
  nextAction           String?
  blocker              String?
  evidenceRefsJson     String?               @db.LongText
  internalNotes        String?               @db.LongText
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, leadKey])
  @@index([workspaceId, stage])
  @@index([workspaceId, ownerMembershipId])
}

// CustomerDemandBrief — V2.3 §7.2 reserved tenant 内部承接对象。
// 把销售收集 / 客户确认 / 内部 review 收敛成一份可复核的 handoff，
// 决定能否进入试用 workspace 初始化。三层分离原则：
//   internalSalesNotes (reserved-only) /
//   customerVisibleSummary (review 后才可示) /
//   trialInitializationPayload (review gate 通过才能复制进试用 workspace)。
model CustomerDemandBrief {
  id                              String                                        @id @default(cuid())
  workspaceId                     String
  leadId                          String
  briefKey                        String
  entryMode                       CustomerDemandBriefEntryMode
  prefillSource                   String?
  customerSummary                 String                                        @db.LongText
  businessPressureTagsJson        String                                        @db.LongText
  currentResourceTagsJson         String                                        @db.LongText
  resourceEvidenceReadinessJson   String                                        @db.LongText
  painToControlLineCandidatesJson String                                        @db.LongText
  roleMapJson                     String                                        @db.LongText
  firstLoopCandidatesJson         String                                        @db.LongText
  successCriteria                 String                                        @db.LongText
  riskBoundaryTagsJson            String                                        @db.LongText
  customerVisibleSummary          String                                        @db.LongText
  internalSalesNotes              String?                                       @db.LongText
  trialInitializationPayloadJson  String?                                       @db.LongText
  sourceTraceJson                 String                                        @db.LongText
  reviewStatus                    CustomerDemandBriefReviewStatus               @default(DRAFT)
  customerConfirmationStatus      CustomerDemandBriefCustomerConfirmationStatus @default(NOT_INVITED)
  createdAt                       DateTime                                      @default(now())
  updatedAt                       DateTime                                      @updatedAt
  workspace                       Workspace                                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, briefKey])
  @@index([workspaceId, leadId])
  @@index([workspaceId, reviewStatus])
}

// OperatingControlLineCandidate — V2.3 §7.4 Phase 3 起点。
// 把客户痛点 + 现有资源 + 初步证据，转成"第一条可验证 / 可复核 / 可初始化试用的
// 经营改善控制线候选"。最小字段集（V2.3 §7.4 第一阶段，回答"能否做"）。
// 第二阶段字段（怎么做 / 怎么验证）延后到 Phase 4/5：missingEvidence /
// helmJudgementScope / humanReviewRequirement / manualActionPlan /
// verificationSignal / nonCommitmentNotes。
model OperatingControlLineCandidate {
  id                   String                                         @id @default(cuid())
  workspaceId          String
  briefId              String
  candidateKey         String
  painTag              String
  controlLineTemplate  OperatingControlLineCandidateTemplate
  targetBusinessObject String
  resourceInputsJson   String                                         @db.LongText
  evidenceReadiness    OperatingControlLineCandidateEvidenceReadiness @default(DECLARED)
  status               OperatingControlLineCandidateStatus            @default(DRAFT)
  evidenceNotesJson    String                                         @db.LongText
  reviewerNotes        String?
  createdAt            DateTime                                       @default(now())
  updatedAt            DateTime                                       @updatedAt
  workspace            Workspace                                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, candidateKey])
  @@index([workspaceId, briefId])
  @@index([workspaceId, status])
}

// CustomerContextUpdateRequest — V2.3 §7.3 客户在注册后或使用过程中补充 / 修正 /
// 改写内容时的 diff/review 跟踪对象。两类 use case：
//   1. initial_confirmation — 注册后、试用初始化前的确认与补全
//   2. in_usage_update — 使用中的补充事实 / 申请改写
//
// 永久边界（V2.3 §10.9）：
//   - minor (联系人 / 目标 / 参与人 / 资料可得性补充) → 可直接 apply，但保留 diff
//   - material (pain tag / control line / 关键资源可用性 / trial premise /
//     owner/reviewer) → 必须 REVIEW_REQUIRED，不可静默覆盖
//   - 客户永远不能改 internalSalesNotes / contribution / accrual / settlement /
//     reviewer decision；这些字段不进 proposedChanges 的允许清单
model CustomerContextUpdateRequest {
  id                     String                                   @id @default(cuid())
  workspaceId            String
  leadId                 String
  briefId                String?
  controlLineCandidateId String?
  requestKey             String
  origin                 CustomerContextUpdateRequestOrigin
  scope                  CustomerContextUpdateRequestScope
  proposedChangesJson    String                                   @db.LongText
  materiality            CustomerContextUpdateRequestMateriality
  reviewStatus           CustomerContextUpdateRequestReviewStatus @default(REVIEW_REQUIRED)
  reviewerActor          String?
  reviewerDecisionNote   String?
  appliedAt              DateTime?
  supersededByRequestId  String?
  sourceTraceJson        String                                   @db.LongText
  createdAt              DateTime                                 @default(now())
  updatedAt              DateTime                                 @updatedAt
  workspace              Workspace                                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, requestKey])
  @@index([workspaceId, briefId])
  @@index([workspaceId, leadId])
  @@index([workspaceId, reviewStatus])
}

// DiagnosticSession — V2.3 §7.5 Phase 4 起点。
// 把 lead + brief + control line 收成"一次诊断"，输出第一条 first-loop 候选 +
// 风险与边界备注。Review-first：诊断不是承诺成功方案；only after human review
// 才能让 lead 进入 FIRST_LOOP_PROPOSED 阶段。
model DiagnosticSession {
  id                     String                  @id @default(cuid())
  workspaceId            String
  leadId                 String
  briefId                String?
  controlLineCandidateId String?
  diagnosticKey          String
  workspaceCandidate     String?
  businessGoal           String
  availableResourcesJson String                  @db.LongText
  roleReadinessJson      String                  @db.LongText
  firstLoopCandidateType FirstLoopType?
  firstLoopCandidateNote String?
  riskNotesJson          String                  @db.LongText
  boundaryNotesJson      String                  @db.LongText
  status                 DiagnosticSessionStatus @default(DRAFT)
  reviewerActor          String?
  reviewerDecisionNote   String?
  sourceTraceJson        String                  @db.LongText
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, diagnosticKey])
  @@index([workspaceId, leadId])
  @@index([workspaceId, status])
}

