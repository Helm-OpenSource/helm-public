      "actor": "customer_member",
      "request": "accept_nudge",
      "nudgeLifecycle": { "from": "submitted", "to": "accepted_by_customer" },
      "grant": { "present": true, "status": "active" },
      "expect": {
        "outcome": "rejected",
        "reasonCodes": ["partner_nudge_acceptance_unauthorized"],
