model User {
  id                           String                    @id @default(cuid())
  email                        String                    @unique
  phone                        String?                   @unique
  name                         String
  title                        String?
  avatar                       String?
  emailVerifiedAt              DateTime?
  phoneVerifiedAt              DateTime?
  passwordHash                 String?
  passwordSetAt                DateTime?
  lastLoginAt                  DateTime?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  memberships                  Membership[]
  ownedContacts                Contact[]                 @relation("ContactOwner")
  ownedOpportunities           Opportunity[]             @relation("OpportunityOwner")
  ownedMeetings                Meeting[]                 @relation("MeetingOwner")
  assignedActions              ActionItem[]              @relation("ActionOwner")
  approvalQueue                ApprovalTask[]            @relation("ApprovalApprover")
  approvalReviews              ApprovalTask[]            @relation("ApprovalReviewer")
  notifications                Notification[]
  auditLogs                    AuditLog[]                @relation("AuditActorUser")
  connectors                   Connector[]
  importSources                ImportSource[]
  importJobs                   ImportJob[]
  eventLogs                    EventLog[]
  usageSnapshots               DailyUsageSnapshot[]
  memoryCorrections            MemoryCorrection[]        @relation("MemoryCorrectionUser")
  ownedCommitments             Commitment[]              @relation("CommitmentOwner")
  recommendationLogs           RecommendationLog[]
  recommendationFeedbacks      RecommendationFeedback[]
  preferenceSignals            PreferenceSignal[]
  llmCallLogs                  LLMCallLog[]
  captureSessions              CaptureSession[]
  usageLedgerEntries           UsageLedger[]
  authVerificationCodes        AuthVerificationCode[]
  authSessions                 AuthSession[]
  participantPortalAccesses    ParticipantPortalAccess[]
  reviewedProgramApplications  ProgramApplication[]      @relation("ProgramApplicationReviewedBy")
  createdBiReportSubscriptions BiReportSubscription[]    @relation("BiReportSubscriptionCreatedBy")
  ownedBiReportBusinessSignals BiReportBusinessSignal[]  @relation("BiReportBusinessSignalOwner")
  reviewedBiReportBusinessHandoffDecisions BiReportBusinessHandoffDecision[] @relation("BiReportBusinessHandoffDecisionReviewedBy")
  authoredBiReportHandoffExecutionLogs BiReportHandoffExecutionLog[] @relation("BiReportHandoffExecutionLogAuthor")
}

model AuthEnrollment {
  id               String                 @id @default(cuid())
  name             String
  email            String                 @unique
  phone            String                 @unique
  organizationName String
  locale           String                 @default("zh-CN")
  passwordHash     String
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  expiresAt        DateTime
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  codes            AuthVerificationCode[]

  @@index([expiresAt])
}

model AuthVerificationCode {
  id           String          @id @default(cuid())
  purpose      AuthCodePurpose
  channel      AuthCodeChannel
  target       String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attempts     Int             @default(0)
  createdAt    DateTime        @default(now())
  enrollmentId String?
  userId       String?
  enrollment   AuthEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([purpose, target, expiresAt])
  @@index([enrollmentId])
  @@index([userId])
}

// Durable per-identifier password-login rate limiting. The identifier
// (email/phone) is hashed, never stored raw; attempts are tracked for any
// identifier so the lockout reveals nothing about account existence.
model FailedLoginAttempt {
  id              String    @id @default(cuid())
  identifierHash  String    @unique
  attemptCount    Int       @default(0)
  windowStartedAt DateTime  @default(now())
  lockedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([lockedUntil])
}

model AuthSession {
  id                    String     @id @default(cuid())
  userId                String
  activeWorkspaceId     String?
  sessionKeyHash        String     @unique
  sourcePage            String?
  providerType          String?
  userAgent             String?
  ipAddress             String?
  lastSeenAt            DateTime   @default(now())
  lastWorkspaceSwitchAt DateTime?
  expiresAt             DateTime
  revokedAt             DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
