      "scenario": "p2_partner_workspace_canceled_collaborator_auto_suspend_candidate",
      "description": "P2 candidate path: PartnerWorkspace canceled triggers auto-suspend candidate for any PARTNER_COLLABORATOR memberships; P0 only captures the offline expectation, no runtime suspend executed.",
      "actor": "system",
      "request": "partner_workspace_cancel_suspend_candidate",
      "p2Candidate": {
        "partnerWorkspaceCanceled": true,
        "autoSuspendCandidateRecorded": true,
