// Structured execution receipt for the light task chain (AgentOS v1.1 receipt
// discipline). One canonical receipt per subject. Free text is supplementary;
// the structured fields are the data the learning loop is allowed to read.
// The helm-v2 official-write chain keeps its own richer proof/ack objects;
// projecting those into this table is deliberately next-layer work.
model ExecutionReceipt {
  id                  String                            @id @default(cuid())
  workspaceId         String
  subjectType         ExecutionReceiptSubjectType
  subjectId           String
  actionItemId        String?                           @unique
  outcome             ExecutionReceiptOutcome
  actionTaken         String
  evidenceRefs        String?                           @db.LongText
  rejectionReasonCode RejectionReasonCode?
  nextStep            String?
  note                String?                           @db.LongText
  // Identity snapshots kept as plain columns (no FK) so attribution survives
  // user deletion; the receipt chain is audit-grade data.
  executedByUserId    String?
  executedByActorType ActorType?
  verifiedByUserId    String?
  verificationState   ExecutionReceiptVerificationState @default(SELF_REPORTED)
  qualityScore        Int                               @default(0)
  qualityFlags        String?                           @db.LongText
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt
  workspace           Workspace                         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actionItem          ActionItem?                       @relation(fields: [actionItemId], references: [id], onDelete: SetNull)

  @@unique([subjectType, subjectId])
  @@index([workspaceId, outcome])
  @@index([workspaceId, verificationState])
}

